# Firebase Client SDK Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_client_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin SDK Configuration (for server-side API routes)
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
# Private Key must preserve newlines. Surround the private key in double quotes and replace real newlines with \n
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# Pluggable Notification System Configuration
# Options: auto | fast2sms | twilio | wati | none
NOTIFICATION_PROVIDER=auto

# Fast2SMS Configuration (India SMS Provider)
FAST2SMS_API_KEY=your_fast2sms_api_key

# Twilio Configuration (Global SMS Provider)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_FROM=your_twilio_from_phone_number

# Wati.io Configuration (WhatsApp Business Provider)
WATI_API_KEY=your_wati_api_key
WATI_BASE_URL=https://live-server-xxxxx.wati.io

# App Global Configurations
NEXT_PUBLIC_SUPPORT_PHONE=9876543210
NEXT_PUBLIC_APP_NAME="FranchExpress ERP"
