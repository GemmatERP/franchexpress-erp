rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }
    
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return isAuth() && getRole() == 'admin';
    }
    
    function isEmployee() {
      return isAuth() && (getRole() == 'employee' || getRole() == 'admin');
    }
    
    match /consignments/{id} {
      allow read: if isAuth();
      allow create, update: if isEmployee();
      allow delete: if isAdmin();
    }
    
    match /users/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }
    
    match /counters/{doc} {
      allow read, write: if isEmployee();
    }
  }
}
